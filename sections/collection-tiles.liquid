{%- if section.blocks.size > 0 -%}
<div class="collection-tiles" id="collection-tiles-{{ section.id }}">
  <div class="collection-tiles__grid">
    {%- for block in section.blocks -%}
      {%- liquid
        assign col = block.settings.collection
        assign label = block.settings.custom_label
        if label == blank
          if col != blank
            assign label = col.title
          else
            assign label = 'Collection'
          endif
        endif
        assign col_url = '#'
        if col != blank
          assign col_url = col.url
        endif
      -%}
      <a
        class="collection-tile"
        href="{{ col_url }}"
        aria-label="{{ label }}"
        {{ block.shopify_attributes }}
      >
        {%- comment -%} Image {%- endcomment -%}
        <div class="collection-tile__media">
          {%- if col != blank and col.featured_image != blank -%}
            {{
              col.featured_image
              | image_url: width: 600
              | image_tag:
                loading: 'lazy',
                class: 'collection-tile__img',
                widths: '300,400,500,600',
                sizes: '(max-width: 749px) 50vw, 17vw',
                alt: label
            }}
          {%- else -%}
            <div class="collection-tile__placeholder">
              {{ 'collection-1' | placeholder_svg_tag: 'collection-tile__placeholder-svg' }}
            </div>
          {%- endif -%}
        </div>

        {%- comment -%} Gradient overlay {%- endcomment -%}
        <div class="collection-tile__overlay"></div>

        {%- comment -%} Text {%- endcomment -%}
        <div class="collection-tile__text">
          <span class="collection-tile__name">{{ label }}</span>
          <span class="collection-tile__shop">Shop Now</span>
        </div>
      </a>
    {%- endfor -%}
  </div>
</div>
{%- endif -%}

<style>
  /* ============================================================
     COLLECTION TILES — wrapper
  ============================================================ */
  #collection-tiles-{{ section.id }} {
    width: 100%;
    padding: 0 20px;
    box-sizing: border-box;
  }

  /* ============================================================
     GRID — 6 columns desktop, 2 columns mobile
  ============================================================ */
  .collection-tiles__grid {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 12px;
    max-width: var(--container-max, 1280px);
    margin: 0 auto;
  }

  /* ============================================================
     TILE — anchor element
  ============================================================ */
  .collection-tile {
    position: relative;
    display: block;
    border-radius: 4px;
    overflow: hidden;
    text-decoration: none;
    background: #1a1a2e;
    cursor: pointer;
  }

  /* ============================================================
     IMAGE MEDIA WRAPPER — aspect ratio
  ============================================================ */
  .collection-tile__media {
    width: 100%;
    aspect-ratio: 1 / 1.2;
    overflow: hidden;
    display: block;
  }

  .collection-tile__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
    transition: transform 400ms ease;
  }

  /* Hover — scale image */
  .collection-tile:hover .collection-tile__img {
    transform: scale(1.06);
  }

  /* ============================================================
     PLACEHOLDER (no image set)
  ============================================================ */
  .collection-tile__placeholder {
    width: 100%;
    aspect-ratio: 1 / 1.2;
    background: #2a2a3e;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: transform 400ms ease;
  }

  .collection-tile:hover .collection-tile__placeholder {
    transform: scale(1.06);
  }

  .collection-tile__placeholder-svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  /* ============================================================
     GRADIENT OVERLAY — bottom fade
  ============================================================ */
  .collection-tile__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(0, 0, 0, 0.65) 0%,
      transparent 55%
    );
    border-radius: 4px;
    pointer-events: none;
  }

  /* ============================================================
     TEXT — pinned to bottom of tile
  ============================================================ */
  .collection-tile__text {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 14px 12px;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  /* Collection name */
  .collection-tile__name {
    font-family: 'Montserrat', sans-serif;
    font-size: 14px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: #ffffff;
    line-height: 1.2;
  }

  /* Shop Now */
  .collection-tile__shop {
    font-family: 'Montserrat', sans-serif;
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: rgba(255, 255, 255, 0.8);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .collection-tile:hover .collection-tile__shop {
    color: #ffffff;
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  /* ============================================================
     RESPONSIVE — tablet: 3 columns
  ============================================================ */
  @media screen and (max-width: 1024px) and (min-width: 750px) {
    .collection-tiles__grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  /* ============================================================
     RESPONSIVE — mobile: 2 columns
  ============================================================ */
  @media screen and (max-width: 749px) {
    #collection-tiles-{{ section.id }} {
      padding: 0 12px;
    }

    .collection-tiles__grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 10px;
    }

    .collection-tile__name {
      font-size: 12px;
      letter-spacing: 0.5px;
    }

    .collection-tile__shop {
      font-size: 10px;
      letter-spacing: 1.5px;
    }

    .collection-tile__text {
      padding: 10px 8px;
    }
  }
</style>

{% schema %}
{
  "name": "Collection Tiles",
  "tag": "section",
  "max_blocks": 12,
  "blocks": [
    {
      "type": "collection",
      "name": "Collection Tile",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection"
        },
        {
          "type": "text",
          "id": "custom_label",
          "label": "Override Label",
          "info": "Leave blank to use the collection title"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Collection Tiles",
      "blocks": [
        { "type": "collection" },
        { "type": "collection" },
        { "type": "collection" },
        { "type": "collection" },
        { "type": "collection" },
        { "type": "collection" }
      ]
    }
  ]
}
{% endschema %}
