{%- if section.blocks.size > 0 -%}
<div class="hero-slider" id="hero-slider-{{ section.id }}" data-section-id="{{ section.id }}">

  <div class="hero-slider__track">
    {%- for block in section.blocks -%}
      <div
        class="hero-slider__slide{% if forloop.first %} hero-slider__slide--active{% endif %}"
        data-index="{{ forloop.index0 }}"
        {{ block.shopify_attributes }}
      >
        {%- comment -%} Background images {%- endcomment -%}
        {%- if block.settings.image != blank -%}
          <div class="hero-slider__bg hero-slider__bg--desktop">
            {{
              block.settings.image
              | image_url: width: 2000
              | image_tag:
                loading: 'eager',
                class: 'hero-slider__img',
                widths: '800,1200,1600,2000',
                sizes: '100vw'
            }}
          </div>
        {%- else -%}
          <div class="hero-slider__bg hero-slider__bg--desktop hero-slider__bg--placeholder"></div>
        {%- endif -%}

        {%- if block.settings.image_mobile != blank -%}
          <div class="hero-slider__bg hero-slider__bg--mobile">
            {{
              block.settings.image_mobile
              | image_url: width: 900
              | image_tag:
                loading: 'eager',
                class: 'hero-slider__img',
                widths: '400,600,800,900',
                sizes: '100vw'
            }}
          </div>
        {%- elsif block.settings.image != blank -%}
          <div class="hero-slider__bg hero-slider__bg--mobile">
            {{
              block.settings.image
              | image_url: width: 900
              | image_tag:
                loading: 'eager',
                class: 'hero-slider__img',
                widths: '400,600,800,900',
                sizes: '100vw'
            }}
          </div>
        {%- else -%}
          <div class="hero-slider__bg hero-slider__bg--mobile hero-slider__bg--placeholder"></div>
        {%- endif -%}

        {%- comment -%} Overlay {%- endcomment -%}
        <div class="hero-slider__overlay"></div>

        {%- comment -%} Text content {%- endcomment -%}
        <div class="hero-slider__content">
          {%- if block.settings.eyebrow != blank -%}
            <p class="hero-slider__eyebrow">{{ block.settings.eyebrow }}</p>
          {%- endif -%}
          {%- if block.settings.heading != blank -%}
            <h2 class="hero-slider__heading">{{ block.settings.heading }}</h2>
          {%- endif -%}
          {%- if block.settings.cta_label != blank -%}
            <a
              class="hero-slider__cta"
              href="{{ block.settings.cta_url | default: '#' }}"
            >
              {{ block.settings.cta_label }}
            </a>
          {%- endif -%}
        </div>
      </div>
    {%- endfor -%}
  </div>

  {%- comment -%} Prev / Next arrows {%- endcomment -%}
  {%- if section.blocks.size > 1 -%}
    <button class="hero-slider__arrow hero-slider__arrow--prev" aria-label="Previous slide">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#ffffff" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="15 18 9 12 15 6"/>
      </svg>
    </button>
    <button class="hero-slider__arrow hero-slider__arrow--next" aria-label="Next slide">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#ffffff" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="9 18 15 12 9 6"/>
      </svg>
    </button>

    {%- comment -%} Dot navigation {%- endcomment -%}
    <div class="hero-slider__dots" role="tablist" aria-label="Slide navigation">
      {%- for block in section.blocks -%}
        <button
          class="hero-slider__dot{% if forloop.first %} hero-slider__dot--active{% endif %}"
          role="tab"
          aria-selected="{% if forloop.first %}true{% else %}false{% endif %}"
          aria-label="Go to slide {{ forloop.index }}"
          data-index="{{ forloop.index0 }}"
        ></button>
      {%- endfor -%}
    </div>
  {%- endif -%}

</div>
{%- endif -%}

<style>
  /* ============================================================
     HERO SLIDER — wrapper
  ============================================================ */
  .hero-slider {
    position: relative;
    width: 100%;
    overflow: hidden;
    background: #111;
  }

  /* ============================================================
     TRACK & SLIDES — fade transition
  ============================================================ */
  .hero-slider__track {
    position: relative;
    width: 100%;
    height: 580px;
  }

  .hero-slider__slide {
    position: absolute;
    inset: 0;
    opacity: 0;
    transition: opacity 600ms ease;
    pointer-events: none;
  }

  .hero-slider__slide--active {
    opacity: 1;
    pointer-events: auto;
  }

  /* ============================================================
     BACKGROUND IMAGES
  ============================================================ */
  .hero-slider__bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .hero-slider__bg--placeholder {
    background-color: #1a1a2e;
  }

  .hero-slider__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
  }

  /* Mobile image hidden on desktop */
  .hero-slider__bg--mobile {
    display: none;
  }

  /* ============================================================
     OVERLAY
  ============================================================ */
  .hero-slider__overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.35);
    z-index: 1;
  }

  /* ============================================================
     TEXT CONTENT — centered over image
  ============================================================ */
  .hero-slider__content {
    position: absolute;
    inset: 0;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 0 24px;
  }

  /* Eyebrow */
  .hero-slider__eyebrow {
    font-family: 'Montserrat', sans-serif;
    font-size: 13px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 3px;
    color: #ffffff;
    margin: 0 0 16px;
  }

  /* Heading */
  .hero-slider__heading {
    font-family: 'Montserrat', sans-serif;
    font-size: 48px;
    font-weight: 800;
    text-transform: uppercase;
    color: #ffffff;
    line-height: 1.1;
    margin: 0 0 28px;
    max-width: 760px;
  }

  /* CTA Button */
  .hero-slider__cta {
    display: inline-block;
    font-family: 'Montserrat', sans-serif;
    font-size: 13px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: #ffffff;
    background-color: #e8192c;
    padding: 14px 36px;
    border-radius: 3px;
    border: none;
    text-decoration: none;
    transition: background-color 0.2s ease;
    cursor: pointer;
  }

  .hero-slider__cta:hover,
  .hero-slider__cta:focus {
    background-color: #c0141f;
    color: #ffffff;
    text-decoration: none;
  }

  /* ============================================================
     ARROW BUTTONS
  ============================================================ */
  .hero-slider__arrow {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 3;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: rgba(0, 0, 0, 0.45);
    border: none;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: background 0.2s ease;
    padding: 0;
  }

  .hero-slider__arrow:hover {
    background: rgba(0, 0, 0, 0.7);
  }

  .hero-slider__arrow--prev {
    left: 16px;
  }

  .hero-slider__arrow--next {
    right: 16px;
  }

  /* ============================================================
     DOT NAVIGATION
  ============================================================ */
  .hero-slider__dots {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 3;
    display: flex;
    gap: 8px;
    align-items: center;
  }

  .hero-slider__dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.5);
    border: 2px solid #ffffff;
    padding: 0;
    cursor: pointer;
    transition: background 0.2s ease, transform 0.2s ease;
  }

  .hero-slider__dot--active {
    background: #ffffff;
    transform: scale(1.25);
  }

  /* ============================================================
     RESPONSIVE — mobile
  ============================================================ */
  @media screen and (max-width: 749px) {
    .hero-slider__track {
      height: 420px;
    }

    .hero-slider__heading {
      font-size: 28px;
      margin-bottom: 20px;
    }

    .hero-slider__eyebrow {
      font-size: 11px;
      letter-spacing: 2px;
    }

    .hero-slider__cta {
      font-size: 12px;
      padding: 12px 28px;
    }

    /* Show mobile image, hide desktop image */
    .hero-slider__bg--desktop {
      display: none;
    }

    .hero-slider__bg--mobile {
      display: block;
    }

    .hero-slider__arrow {
      width: 32px;
      height: 32px;
    }

    .hero-slider__arrow--prev {
      left: 10px;
    }

    .hero-slider__arrow--next {
      right: 10px;
    }
  }
</style>

<script>
  (function () {
    var slider = document.getElementById('hero-slider-{{ section.id }}');
    if (!slider) return;

    var slides = slider.querySelectorAll('.hero-slider__slide');
    var dots = slider.querySelectorAll('.hero-slider__dot');
    var prevBtn = slider.querySelector('.hero-slider__arrow--prev');
    var nextBtn = slider.querySelector('.hero-slider__arrow--next');
    var total = slides.length;
    var current = 0;
    var timer = null;

    if (total <= 1) return;

    function goTo(index) {
      slides[current].classList.remove('hero-slider__slide--active');
      if (dots[current]) {
        dots[current].classList.remove('hero-slider__dot--active');
        dots[current].setAttribute('aria-selected', 'false');
      }

      current = (index + total) % total;

      slides[current].classList.add('hero-slider__slide--active');
      if (dots[current]) {
        dots[current].classList.add('hero-slider__dot--active');
        dots[current].setAttribute('aria-selected', 'true');
      }
    }

    function startTimer() {
      clearInterval(timer);
      timer = setInterval(function () {
        goTo(current + 1);
      }, 5000);
    }

    function resetTimer() {
      startTimer();
    }

    if (prevBtn) {
      prevBtn.addEventListener('click', function () {
        goTo(current - 1);
        resetTimer();
      });
    }

    if (nextBtn) {
      nextBtn.addEventListener('click', function () {
        goTo(current + 1);
        resetTimer();
      });
    }

    dots.forEach(function (dot) {
      dot.addEventListener('click', function () {
        var idx = parseInt(dot.getAttribute('data-index'), 10);
        goTo(idx);
        resetTimer();
      });
    });

    /* Pause on hover */
    slider.addEventListener('mouseenter', function () {
      clearInterval(timer);
    });
    slider.addEventListener('mouseleave', function () {
      startTimer();
    });

    /* Pause when not in viewport */
    if ('IntersectionObserver' in window) {
      var observer = new IntersectionObserver(function (entries) {
        entries.forEach(function (entry) {
          if (entry.isIntersecting) {
            startTimer();
          } else {
            clearInterval(timer);
          }
        });
      }, { threshold: 0.25 });
      observer.observe(slider);
    } else {
      startTimer();
    }
  })();
</script>

{% schema %}
{
  "name": "Hero Slider",
  "tag": "section",
  "max_blocks": 6,
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Desktop Image"
        },
        {
          "type": "image_picker",
          "id": "image_mobile",
          "label": "Mobile Image"
        },
        {
          "type": "text",
          "id": "eyebrow",
          "label": "Eyebrow Text"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Main Heading"
        },
        {
          "type": "text",
          "id": "cta_label",
          "label": "Button Text",
          "default": "SHOP NOW"
        },
        {
          "type": "url",
          "id": "cta_url",
          "label": "Button Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Hero Slider",
      "blocks": [
        {
          "type": "slide",
          "settings": {
            "eyebrow": "New Collection",
            "heading": "Discover Our Latest Mugs",
            "cta_label": "SHOP NOW"
          }
        },
        {
          "type": "slide",
          "settings": {
            "eyebrow": "Free Delivery",
            "heading": "Orders Above Rs 10,000",
            "cta_label": "SHOP NOW"
          }
        }
      ]
    }
  ]
}
{% endschema %}
