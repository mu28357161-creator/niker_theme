{%- liquid
  assign text_pos = section.settings.text_position | default: 'left'
-%}

<div class="promo-banner promo-banner--text-{{ text_pos }}" id="promo-banner-{{ section.id }}">

  {%- comment -%} Desktop image {%- endcomment -%}
  {%- if section.settings.image != blank -%}
    <div class="promo-banner__bg promo-banner__bg--desktop">
      {{
        section.settings.image
        | image_url: width: 2000
        | image_tag:
          loading: 'lazy',
          class: 'promo-banner__img',
          widths: '800,1200,1600,2000',
          sizes: '100vw'
      }}
    </div>
  {%- else -%}
    <div class="promo-banner__bg promo-banner__bg--desktop promo-banner__bg--placeholder"></div>
  {%- endif -%}

  {%- comment -%} Mobile image (falls back to desktop if not set) {%- endcomment -%}
  {%- if section.settings.image_mobile != blank -%}
    <div class="promo-banner__bg promo-banner__bg--mobile">
      {{
        section.settings.image_mobile
        | image_url: width: 900
        | image_tag:
          loading: 'lazy',
          class: 'promo-banner__img',
          widths: '400,600,800,900',
          sizes: '100vw'
      }}
    </div>
  {%- elsif section.settings.image != blank -%}
    <div class="promo-banner__bg promo-banner__bg--mobile">
      {{
        section.settings.image
        | image_url: width: 900
        | image_tag:
          loading: 'lazy',
          class: 'promo-banner__img',
          widths: '400,600,800,900',
          sizes: '100vw'
      }}
    </div>
  {%- else -%}
    <div class="promo-banner__bg promo-banner__bg--mobile promo-banner__bg--placeholder"></div>
  {%- endif -%}

  {%- comment -%} Gradient overlay {%- endcomment -%}
  <div class="promo-banner__overlay"></div>

  {%- comment -%} Text content {%- endcomment -%}
  <div class="promo-banner__content">
    {%- if section.settings.subheading != blank -%}
      <p class="promo-banner__subheading">{{ section.settings.subheading }}</p>
    {%- endif -%}
    {%- if section.settings.heading != blank -%}
      <h2 class="promo-banner__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}
    {%- if section.settings.cta_label != blank -%}
      <a
        class="promo-banner__cta"
        href="{{ section.settings.cta_url | default: '#' }}"
      >
        {{ section.settings.cta_label }}
      </a>
    {%- endif -%}
  </div>

</div>

<style>
  /* ============================================================
     PROMO BANNER — wrapper
  ============================================================ */
  #promo-banner-{{ section.id }} {
    position: relative;
    width: 100%;
    min-height: 400px;
    overflow: hidden;
    display: flex;
    align-items: stretch;
  }

  /* ============================================================
     BACKGROUND IMAGES
  ============================================================ */
  .promo-banner__bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .promo-banner__bg--placeholder {
    background-color: #1a1a2e;
  }

  .promo-banner__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
  }

  /* Mobile image hidden on desktop */
  .promo-banner__bg--mobile {
    display: none;
  }

  /* ============================================================
     GRADIENT OVERLAY
  ============================================================ */
  .promo-banner__overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    background: linear-gradient(
      to right,
      rgba(0, 0, 0, 0.6) 0%,
      rgba(0, 0, 0, 0.1) 100%
    );
  }

  /* Flip gradient for right-aligned text */
  .promo-banner--text-right .promo-banner__overlay {
    background: linear-gradient(
      to left,
      rgba(0, 0, 0, 0.6) 0%,
      rgba(0, 0, 0, 0.1) 100%
    );
  }

  /* Full center overlay for centered text */
  .promo-banner--text-center .promo-banner__overlay {
    background: rgba(0, 0, 0, 0.45);
  }

  /* ============================================================
     TEXT CONTENT — position variants
  ============================================================ */
  .promo-banner__content {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 60px 20px;
    width: 100%;
  }

  /* Left */
  .promo-banner--text-left .promo-banner__content {
    align-items: flex-start;
    text-align: left;
    padding-left: clamp(24px, 8vw, 30%);
    padding-right: clamp(24px, 8vw, 30%);
    max-width: 680px;
  }

  /* Center */
  .promo-banner--text-center .promo-banner__content {
    align-items: center;
    text-align: center;
    margin: 0 auto;
    max-width: 760px;
    padding-left: 24px;
    padding-right: 24px;
  }

  /* Right */
  .promo-banner--text-right .promo-banner__content {
    align-items: flex-end;
    text-align: right;
    margin-left: auto;
    padding-right: clamp(24px, 8vw, 30%);
    padding-left: clamp(24px, 8vw, 10%);
    max-width: 680px;
  }

  /* ============================================================
     SUBHEADING
  ============================================================ */
  .promo-banner__subheading {
    font-family: 'Montserrat', sans-serif;
    font-size: 13px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 3px;
    color: #ffffff;
    margin: 0 0 14px;
  }

  /* ============================================================
     MAIN HEADING
  ============================================================ */
  .promo-banner__heading {
    font-family: 'Montserrat', sans-serif;
    font-size: 42px;
    font-weight: 800;
    text-transform: uppercase;
    color: #ffffff;
    line-height: 1.1;
    margin: 0 0 28px;
  }

  /* ============================================================
     CTA BUTTON
  ============================================================ */
  .promo-banner__cta {
    display: inline-block;
    font-family: 'Montserrat', sans-serif;
    font-size: 13px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: #ffffff;
    background-color: #e8192c;
    padding: 12px 32px;
    border-radius: 3px;
    border: none;
    text-decoration: none;
    transition: background-color 0.2s ease;
    cursor: pointer;
    align-self: flex-start;
  }

  .promo-banner--text-center .promo-banner__cta {
    align-self: center;
  }

  .promo-banner--text-right .promo-banner__cta {
    align-self: flex-end;
  }

  .promo-banner__cta:hover,
  .promo-banner__cta:focus {
    background-color: #c0141f;
    color: #ffffff;
    text-decoration: none;
  }

  /* ============================================================
     RESPONSIVE — mobile
  ============================================================ */
  @media screen and (max-width: 749px) {
    #promo-banner-{{ section.id }} {
      min-height: 320px;
    }

    /* Swap to mobile image */
    .promo-banner__bg--desktop {
      display: none;
    }

    .promo-banner__bg--mobile {
      display: block;
    }

    /* Override all position variants to center on mobile */
    .promo-banner--text-left .promo-banner__content,
    .promo-banner--text-right .promo-banner__content,
    .promo-banner--text-center .promo-banner__content {
      align-items: center;
      text-align: center;
      margin: 0 auto;
      max-width: 100%;
      padding: 48px 24px;
    }

    .promo-banner--text-left .promo-banner__overlay,
    .promo-banner--text-right .promo-banner__overlay {
      background: rgba(0, 0, 0, 0.45);
    }

    .promo-banner__heading {
      font-size: 24px;
      margin-bottom: 20px;
    }

    .promo-banner__subheading {
      font-size: 11px;
      letter-spacing: 2px;
    }

    .promo-banner__cta {
      font-size: 12px;
      padding: 11px 26px;
      align-self: center;
    }
  }
</style>

{% schema %}
{
  "name": "Promo Banner",
  "tag": "section",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Desktop Image"
    },
    {
      "type": "image_picker",
      "id": "image_mobile",
      "label": "Mobile Image"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Main Heading"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Button Label",
      "default": "SHOP NOW"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "Button URL"
    },
    {
      "type": "select",
      "id": "text_position",
      "label": "Text Position",
      "default": "left",
      "options": [
        { "value": "left",   "label": "Left"   },
        { "value": "center", "label": "Center" },
        { "value": "right",  "label": "Right"  }
      ]
    }
  ],
  "presets": [
    {
      "name": "Promo Banner",
      "settings": {
        "subheading": "Customised",
        "heading": "Corporate Gifts",
        "cta_label": "SHOP NOW",
        "text_position": "left"
      }
    }
  ]
}
{% endschema %}
