{%- assign featured_collection = collections[section.settings.collection] -%}

<style>
  #fp-{{ section.id }} {
    padding: 60px 40px;
    background: #ffffff;
  }
  #fp-{{ section.id }} .fp__heading-wrap {
    text-align: center;
    margin-bottom: 40px;
  }
  #fp-{{ section.id }} .fp__heading {
    font-family: 'Montserrat', sans-serif;
    font-size: 28px;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: #1a1a2e;
    margin: 0 0 12px 0;
  }
  #fp-{{ section.id }} .fp__heading-bar {
    width: 60px;
    height: 3px;
    background: #e8192c;
    margin: 0 auto;
  }
  #fp-{{ section.id }} .fp__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
    max-width: 1280px;
    margin: 0 auto;
  }
  #fp-{{ section.id }} .fp__card {
    display: block;
    text-decoration: none;
    position: relative;
  }
  #fp-{{ section.id }} .fp__card-image-wrap {
    position: relative;
    overflow: hidden;
    border-radius: 4px;
    aspect-ratio: 1 / 1;
  }
  #fp-{{ section.id }} .fp__card-image-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 350ms ease;
  }
  #fp-{{ section.id }} .fp__card:hover .fp__card-image-wrap img {
    transform: scale(1.04);
  }
  #fp-{{ section.id }} .fp__badge {
    position: absolute;
    top: 10px;
    left: 10px;
    background: #e8192c;
    color: #ffffff;
    font-family: 'Montserrat', sans-serif;
    font-size: 10px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
    padding: 4px 8px;
    border-radius: 2px;
    z-index: 2;
  }
  #fp-{{ section.id }} .fp__card-info {
    padding: 12px 0 0;
  }
  #fp-{{ section.id }} .fp__card-title {
    font-family: 'Montserrat', sans-serif;
    font-size: 13px;
    font-weight: 600;
    color: #1a1a2e;
    line-height: 1.4;
    margin: 0 0 6px;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  #fp-{{ section.id }} .fp__card-title:hover {
    color: #e8192c;
  }
  #fp-{{ section.id }} .fp__price-row {
    display: flex;
    align-items: center;
    gap: 8px;
  }
  #fp-{{ section.id }} .fp__price {
    font-family: 'Montserrat', sans-serif;
    font-size: 14px;
    font-weight: 700;
    color: #1a1a2e;
  }
  #fp-{{ section.id }} .fp__price--sale {
    color: #e8192c;
  }
  #fp-{{ section.id }} .fp__price--compare {
    font-size: 12px;
    color: #999999;
    text-decoration: line-through;
    font-weight: 400;
  }
  #fp-{{ section.id }} .fp__empty {
    text-align: center;
    color: #999;
    font-family: 'Open Sans', sans-serif;
    font-size: 14px;
    padding: 40px 0;
  }
  @media screen and (max-width: 1024px) {
    #fp-{{ section.id }} .fp__grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
  @media screen and (max-width: 767px) {
    #fp-{{ section.id }} {
      padding: 40px 20px;
    }
    #fp-{{ section.id }} .fp__grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 12px;
    }
    #fp-{{ section.id }} .fp__heading {
      font-size: 22px;
    }
  }
</style>

<div id="fp-{{ section.id }}">
  <div class="fp__heading-wrap">
    <h2 class="fp__heading">{{ section.settings.heading }}</h2>
    <div class="fp__heading-bar"></div>
  </div>

  {%- if featured_collection != blank and featured_collection.products.size > 0 -%}
    <div class="fp__grid">
      {%- for product in featured_collection.products limit: section.settings.products_count -%}
        <a class="fp__card" href="{{ product.url }}">
          <div class="fp__card-image-wrap">
            {%- if product.compare_at_price > product.price -%}
              <span class="fp__badge">SALE</span>
            {%- endif -%}
            {%- if product.featured_image -%}
              <img
                src="{{ product.featured_image | image_url: width: 600 }}"
                alt="{{ product.title | escape }}"
                loading="lazy"
                width="600"
                height="600"
              >
            {%- else -%}
              {{ 'product-1' | placeholder_svg_tag }}
            {%- endif -%}
          </div>
          <div class="fp__card-info">
            <p class="fp__card-title">{{ product.title }}</p>
            <div class="fp__price-row">
              {%- if product.compare_at_price > product.price -%}
                <span class="fp__price--compare">{{ product.compare_at_price | money }}</span>
                <span class="fp__price fp__price--sale">{{ product.price | money }}</span>
              {%- else -%}
                <span class="fp__price">{{ product.price | money }}</span>
              {%- endif -%}
            </div>
          </div>
        </a>
      {%- endfor -%}
    </div>
  {%- else -%}
    <p class="fp__empty">Select a collection in the theme editor to display products.</p>
  {%- endif -%}
</div>

{% schema %}
{
  "name": "Featured Products",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "FIND THE PERFECT GIFT"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_count",
      "label": "Number of Products",
      "min": 4,
      "max": 24,
      "step": 4,
      "default": 12
    }
  ],
  "presets": [
    {
      "name": "Featured Products"
    }
  ]
}
{% endschema %}