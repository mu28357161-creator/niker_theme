<style>
  /* ============================================================
     PRODUCT PAGE — 2-column layout (media left, info right)
  ============================================================ */
  .product-information__grid {
    display: grid !important;
    grid-template-columns: 55% 45% !important;
    gap: 40px !important;
    align-items: start !important;
  }

  /* ============================================================
     PRODUCT MEDIA — main image container
  ============================================================ */
  .product-media-container {
    border-radius: 6px;
    border: 1px solid #e0e0e0;
    overflow: hidden;
  }

  .product-media-container--image,
  .product-media-container--force-aspect {
    aspect-ratio: 1 / 1;
  }

  .product-media__image,
  .product-media-container img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
    border-radius: 6px;
  }

  /* ============================================================
     THUMBNAILS — row below main image
  ============================================================ */
  .dialog-thumbnails-list,
  .media-gallery__grid .product-media-container:not(:first-child) {
    display: flex;
    flex-direction: row;
    gap: 8px;
    flex-wrap: wrap;
    margin-top: 10px;
  }

  .dialog-thumbnails-list__thumbnail,
  .slideshow-controls__thumbnail {
    width: 70px;
    height: 70px;
    flex-shrink: 0;
    border-radius: 4px;
    border: 2px solid transparent;
    overflow: hidden;
    cursor: pointer;
    transition: border-color 200ms ease;
  }

  .dialog-thumbnails-list__thumbnail img,
  .slideshow-controls__thumbnail img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
  }

  .dialog-thumbnails-list__thumbnail:hover,
  .slideshow-controls__thumbnail:hover,
  .dialog-thumbnails-list__thumbnail[aria-selected="true"],
  .slideshow-controls__thumbnail[aria-selected="true"],
  .dialog-thumbnails-list__thumbnail.is-active,
  .slideshow-controls__thumbnail.is-active {
    border-color: #e8192c;
  }

  /* ============================================================
     PRODUCT INFO PANEL — wrapper
  ============================================================ */
  .product-information__details,
  .product-information__content,
  .product-information .group-block-content {
    display: flex;
    flex-direction: column;
  }

  /* ============================================================
     PRODUCT TITLE
  ============================================================ */
  .product-information h1,
  .product-information .product__title,
  .product-information__details h1 {
    font-family: 'Montserrat', sans-serif !important;
    font-size: 24px !important;
    font-weight: 800 !important;
    color: #1a1a2e !important;
    margin-bottom: 12px !important;
    line-height: 1.2 !important;
  }

  /* ============================================================
     PRICE
  ============================================================ */
  .price__sale .price-item--sale,
  .price__regular .price-item--regular,
  .price-item--sale {
    font-family: 'Montserrat', sans-serif !important;
    font-size: 26px !important;
    font-weight: 700 !important;
    color: #e8192c !important;
  }

  /* Regular (non-sale) price */
  .price__regular .price-item--regular {
    font-family: 'Montserrat', sans-serif !important;
    font-size: 26px !important;
    font-weight: 700 !important;
    color: #e8192c !important;
  }

  /* Compare-at / was price */
  .compare-at-price,
  .price-item--regular + .compare-at-price,
  .price__sale .compare-at-price {
    font-family: 'Open Sans', sans-serif !important;
    font-size: 16px !important;
    font-weight: 400 !important;
    color: #999999 !important;
    text-decoration: line-through !important;
    margin-right: 8px !important;
  }

  /* ============================================================
     SHORT DESCRIPTION / RTE TEXT
  ============================================================ */
  .product-information .rte,
  .product-information .text-block p,
  .product-information .text-block,
  .product-information__details .rte {
    font-family: 'Open Sans', sans-serif !important;
    font-size: 14px !important;
    color: #555555 !important;
    line-height: 1.7 !important;
    margin: 16px 0 !important;
  }

  /* ============================================================
     VARIANT PICKER — option group labels
  ============================================================ */
  .variant-option legend,
  .variant-option__legend,
  .variant-option > label,
  .variant-picker .variant-option > span:first-child {
    font-family: 'Montserrat', sans-serif !important;
    font-size: 11px !important;
    font-weight: 700 !important;
    text-transform: uppercase !important;
    letter-spacing: 1px !important;
    color: #1a1a2e !important;
    margin-bottom: 6px !important;
    display: block;
  }

  /* Variant buttons (pill style) */
  .variant-option__button-label,
  .variant-option__button-label__pill {
    border: 1px solid #d0d0d0 !important;
    padding: 8px 16px !important;
    border-radius: 3px !important;
    font-family: 'Montserrat', sans-serif !important;
    font-size: 12px !important;
    font-weight: 600 !important;
    color: #1a1a2e !important;
    cursor: pointer !important;
    transition: border-color 200ms ease, background 200ms ease, color 200ms ease !important;
    display: inline-flex !important;
    align-items: center !important;
    justify-content: center !important;
    text-align: center !important;
    background: #ffffff !important;
  }

  .variant-option__button-label:hover {
    border-color: #1a1a2e !important;
  }

  /* Selected variant button — input:checked triggers this via sibling */
  .variant-option input[type="radio"]:checked + .variant-option__button-label,
  .variant-option input[type="radio"]:checked ~ .variant-option__button-label,
  .variant-option__button-label.is-selected,
  .variant-option__button-label[aria-pressed="true"] {
    border-color: #1a1a2e !important;
    background-color: #1a1a2e !important;
    color: #ffffff !important;
  }

  /* Variant dropdown (select style) */
  .variant-option__select {
    font-family: 'Montserrat', sans-serif !important;
    font-size: 12px !important;
    color: #1a1a2e !important;
    border: 1px solid #d0d0d0 !important;
    padding: 8px 12px !important;
    border-radius: 3px !important;
    background: #ffffff !important;
    cursor: pointer !important;
    width: 100% !important;
  }

  .variant-option__select:focus {
    border-color: #1a1a2e !important;
    outline: none !important;
  }

  /* ============================================================
     QUANTITY SELECTOR
  ============================================================ */
  .quantity-selector {
    display: flex !important;
    align-items: center !important;
    border: 1px solid #d0d0d0 !important;
    border-radius: 3px !important;
    overflow: hidden !important;
    width: fit-content !important;
  }

  .quantity-selector input[type="number"],
  .quantity-selector__input {
    border: none !important;
    border-left: 1px solid #d0d0d0 !important;
    border-right: 1px solid #d0d0d0 !important;
    padding: 8px 12px !important;
    width: 70px !important;
    text-align: center !important;
    font-family: 'Montserrat', sans-serif !important;
    font-size: 13px !important;
    font-weight: 600 !important;
    color: #1a1a2e !important;
    background: #ffffff !important;
    outline: none !important;
    -moz-appearance: textfield;
  }

  .quantity-selector input[type="number"]::-webkit-inner-spin-button,
  .quantity-selector input[type="number"]::-webkit-outer-spin-button {
    -webkit-appearance: none;
    margin: 0;
  }

  .quantity-minus,
  .quantity-plus {
    background: #f8f8f8 !important;
    border: none !important;
    padding: 8px 12px !important;
    font-size: 16px !important;
    font-weight: 700 !important;
    color: #1a1a2e !important;
    cursor: pointer !important;
    transition: background 150ms ease !important;
    line-height: 1 !important;
  }

  .quantity-minus:hover,
  .quantity-plus:hover {
    background: #e0e0e0 !important;
  }

  /* ============================================================
     ADD TO CART BUTTON
  ============================================================ */
  .add-to-cart-button,
  [name="add"] {
    display: block !important;
    width: 100% !important;
    background-color: #e8192c !important;
    color: #ffffff !important;
    font-family: 'Montserrat', sans-serif !important;
    font-size: 14px !important;
    font-weight: 700 !important;
    text-transform: uppercase !important;
    letter-spacing: 2px !important;
    padding: 16px !important;
    border-radius: 3px !important;
    border: none !important;
    text-align: center !important;
    cursor: pointer !important;
    margin-top: 20px !important;
    transition: background-color 300ms ease !important;
    text-decoration: none !important;
    box-sizing: border-box !important;
  }

  .add-to-cart-button:hover,
  [name="add"]:hover {
    background-color: #c0141f !important;
  }

  .add-to-cart-button:disabled,
  [name="add"]:disabled {
    background-color: #cccccc !important;
    cursor: not-allowed !important;
  }

  /* ATC text inside button */
  .add-to-cart-text,
  .add-to-cart-text__content {
    font-family: 'Montserrat', sans-serif !important;
    font-size: 14px !important;
    font-weight: 700 !important;
    text-transform: uppercase !important;
    letter-spacing: 2px !important;
    color: #ffffff !important;
  }

  /* Sticky ATC bar at bottom on scroll */
  .sticky-add-to-cart__button {
    background-color: #e8192c !important;
    color: #ffffff !important;
    font-family: 'Montserrat', sans-serif !important;
    font-size: 13px !important;
    font-weight: 700 !important;
    text-transform: uppercase !important;
    letter-spacing: 1.5px !important;
    border-radius: 3px !important;
    transition: background-color 300ms ease !important;
  }

  .sticky-add-to-cart__button:hover {
    background-color: #c0141f !important;
  }

  .sticky-add-to-cart__title {
    font-family: 'Montserrat', sans-serif !important;
    font-size: 14px !important;
    font-weight: 700 !important;
    color: #1a1a2e !important;
  }

  .sticky-add-to-cart__price .price-item--sale,
  .sticky-add-to-cart__price .price-item--regular {
    font-family: 'Montserrat', sans-serif !important;
    font-size: 15px !important;
    font-weight: 700 !important;
    color: #e8192c !important;
  }

  /* ============================================================
     TRUST BADGES ROW (custom utility class)
  ============================================================ */
  .product-trust-badges {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 16px;
    margin-top: 16px;
  }

  .product-trust-badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: 'Open Sans', sans-serif;
    font-size: 12px;
    color: #666666;
    line-height: 1.4;
  }

  .product-trust-badge svg {
    width: 16px;
    height: 16px;
    flex-shrink: 0;
    color: #1a1a2e;
  }

  /* ============================================================
     RESPONSIVE — mobile: single column
  ============================================================ */
  @media screen and (max-width: 749px) {
    .product-information__grid {
      grid-template-columns: 1fr !important;
      gap: 24px !important;
    }

    .product-information h1,
    .product-information .product__title,
    .product-information__details h1 {
      font-size: 20px !important;
    }

    .price__sale .price-item--sale,
    .price__regular .price-item--regular,
    .price-item--sale {
      font-size: 22px !important;
    }

    .add-to-cart-button,
    [name="add"] {
      font-size: 13px !important;
      padding: 14px !important;
    }

    .product-trust-badges {
      gap: 12px;
    }
  }
</style>
