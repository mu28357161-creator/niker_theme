  </ul>
</nav>

<script>
(function () {
  'use strict';

  /* ── Hamburger button ── */
  function buildHamburger() {
    var existing = document.getElementById('mugshot-hamburger');
    if (existing) return existing;

    var btn = document.createElement('button');
    btn.id = 'mugshot-hamburger';
    btn.className = 'mugshot-hamburger';
    btn.setAttribute('aria-label', 'Open navigation menu');
    btn.setAttribute('aria-expanded', 'false');
    btn.setAttribute('aria-controls', 'mugshot-mobile-nav');
    btn.innerHTML =
      '<span class="mugshot-hamburger__line"></span>' +
      '<span class="mugshot-hamburger__line"></span>' +
      '<span class="mugshot-hamburger__line"></span>';

    /* Insert as first child of the left header column */
    var leftCol = document.querySelector('.header__column--left');
    if (leftCol) {
      leftCol.insertBefore(btn, leftCol.firstChild);
    } else {
      var cols = document.querySelector('.header__columns');
      if (cols) cols.insertBefore(btn, cols.firstChild);
    }
    return btn;
  }

  /* ── Clone desktop nav links into mobile drawer ── */
  function populateMobileNav() {
    var list = document.getElementById('mugshot-mobile-nav-list');
    if (!list || list.children.length > 0) return;

    var links = document.querySelectorAll(
      '.header__column--center .menu-list__link, ' +
      '.header-menu .menu-list__link'
    );

    if (!links.length) {
      /* Fallback: try any menu-list link */
      links = document.querySelectorAll('.menu-list__list > .menu-list__list-item > .menu-list__link');
    }

    links.forEach(function (link) {
      var li = document.createElement('li');
      li.className = 'mugshot-mobile-nav__item';
      var a = document.createElement('a');
      a.href = link.href || '#';
      a.textContent = (link.querySelector('.menu-list__link-title') || link).textContent.trim();
      li.appendChild(a);
      list.appendChild(li);
    });
  }

  /* ── Open / close ── */
  function openNav() {
    var nav      = document.getElementById('mugshot-mobile-nav');
    var backdrop = document.getElementById('mugshot-nav-backdrop');
    var btn      = document.getElementById('mugshot-hamburger');
    if (!nav) return;
    nav.classList.add('is-open');
    nav.setAttribute('aria-hidden', 'false');
    if (backdrop) backdrop.classList.add('is-open');
    if (btn) { btn.classList.add('is-open'); btn.setAttribute('aria-expanded', 'true'); }
    document.body.style.overflow = 'hidden';
  }

  function closeNav() {
    var nav      = document.getElementById('mugshot-mobile-nav');
    var backdrop = document.getElementById('mugshot-nav-backdrop');
    var btn      = document.getElementById('mugshot-hamburger');
    if (!nav) return;
    nav.classList.remove('is-open');
    nav.setAttribute('aria-hidden', 'true');
    if (backdrop) backdrop.classList.remove('is-open');
    if (btn) { btn.classList.remove('is-open'); btn.setAttribute('aria-expanded', 'false'); }
    document.body.style.overflow = '';
  }

  /* ── Init ── */
  function init() {
    buildHamburger();
    populateMobileNav();

    var hamburger = document.getElementById('mugshot-hamburger');
    var closeBtn  = document.getElementById('mugshot-nav-close');
    var backdrop  = document.getElementById('mugshot-nav-backdrop');

    if (hamburger) {
      hamburger.addEventListener('click', function () {
        var nav = document.getElementById('mugshot-mobile-nav');
        if (nav && nav.classList.contains('is-open')) { closeNav(); } else { openNav(); }
      });
    }

    if (closeBtn)  closeBtn.addEventListener('click', closeNav);
    if (backdrop)  backdrop.addEventListener('click', closeNav);

    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape') closeNav();
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
})();
</script>
