    line-height: 2.2 !important;
    text-decoration: none !important;
    display: block;
    transition: color 200ms ease, padding-left 200ms ease !important;
  }

  .menu__item a:hover,
  footer .list-unstyled li a:hover {
    color: #ffffff !important;
    padding-left: 4px !important;
  }

