<style>
  /* ============================================================
     FOOTER — section background & top border
  ============================================================ */
  .footer-section .section-background,
  .footer-section > .section-background {
    background-color: #1a1a2e !important;
  }

  footer .section,
  .footer-section .section,
  .footer-section .section--full-width,
  .footer-section .section--large,
  .footer-section .section--medium,
  .footer-section .section--small {
    background-color: #1a1a2e;
    color: rgba(255, 255, 255, 0.75);
    border-top: 3px solid #e8192c;
    padding-top: 60px;
    padding-bottom: 30px;
  }

  /* Catch-all for Tinker's color scheme classes applied to footer */
  footer [class*='color-'] {
    background-color: #1a1a2e;
    color: rgba(255, 255, 255, 0.75);
  }

  /* ============================================================
     FOOTER CONTENT — 4-column grid
  ============================================================ */
  .footer-content {
