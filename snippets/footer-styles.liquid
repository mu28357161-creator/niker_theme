    letter-spacing: 2px !important;
    color: #ffffff !important;
    margin-bottom: 16px !important;
    padding-bottom: 10px !important;
    position: relative !important;
  }

  /* Red underline bar via pseudo-element */
  .menu__heading::after,
  .menu__heading__default::after,
  .email-signup__heading::after,
  footer h2::after,
  footer h3::after,
  footer h4::after {
    content: '';
    display: block;
    width: 30px;
    height: 2px;
    background-color: #e8192c;
    margin-top: 8px;
  }

  /* ============================================================
     NAVIGATION / MENU LINKS
  ============================================================ */
  .menu .list-unstyled,
  footer .list-unstyled {
    list-style: none !important;
    padding: 0 !important;
    margin: 0 !important;
  }

